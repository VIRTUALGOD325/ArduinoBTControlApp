<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- Full-screen camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/gradientFade"/>

    <!-- Detection overlay on top of camera -->
    <com.eduprime.arduinobt.views.DetectionOverlayView
        android:id="@+id/detectionOverlay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/gradientFade"/>

    <!-- Gradient fade at the bottom of the camera view -->
    <View
        android:id="@+id/gradientFade"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_gradient_top"
        android:alpha="0.7"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"/>

    <!-- ── Top status bar ── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/btStatusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/circle_red"/>

        <TextView
            android:id="@+id/btStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Not Connected"
            android:textColor="#E5E2E1"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/detectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👁️ Scanning..."
            android:textColor="#A8FF78"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- ── Mode tabs ── -->
    <LinearLayout
        android:id="@+id/modeTabs"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:gravity="center"
        android:background="#BB000000"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <TextView
            android:id="@+id/tabDetect"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:text="🔍 DETECT"
            android:textColor="#A8FF78"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_green"/>

        <TextView
            android:id="@+id/tabTrack"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:text="🎯 TRACK"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_yellow"/>

        <TextView
            android:id="@+id/tabTrain"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🎓 TEACH"
            android:textColor="#FF9EC4"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_pink"/>
    </LinearLayout>

    <!-- ── Bottom panel ── -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D0D0D"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <!-- Detection result card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_dark"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <!-- Lottie scanning animation (visible when idle) -->
            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/animScanning"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:lottie_fileName="anim_scanning.json"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"/>

            <!-- Lottie detected animation (visible on match, hidden otherwise) -->
            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/animDetected"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:visibility="gone"
                app:lottie_fileName="anim_detected.json"
                app:lottie_autoPlay="false"
                app:lottie_loop="false"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/detectedName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nothing detected yet"
                    android:textColor="#E5E2E1"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/detectedConf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Point camera at something!"
                    android:textColor="#89919D"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:ellipsize="end"/>
            </LinearLayout>

            <TextView
                android:id="@+id/detectedCommand"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:gravity="center"
                android:text="--"
                android:textColor="#9ECAFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:background="@drawable/bg_card_dark"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- Auto-drive row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_dark"
            android:paddingHorizontal="20dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚗  Auto-Drive"
                    android:textColor="#E5E2E1"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Send commands automatically"
                    android:textColor="#89919D"
                    android:textSize="11sp"/>
            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/autoDriveSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ── Bottom navigation ── -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D0D"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
