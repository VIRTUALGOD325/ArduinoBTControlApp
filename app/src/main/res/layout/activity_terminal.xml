<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/stat_sys_data_bluetooth"
            android:tint="#9ECAFF"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Terminal"
            android:textColor="#E5E2E1"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="#9ECAFF"
            android:layout_marginEnd="16dp"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_manage"
            android:tint="#9ECAFF"/>
    </LinearLayout>

    <!-- Serial Interface Header -->
    <LinearLayout
        android:id="@+id/serialHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SERIAL INTERFACE"
            android:textColor="#9ECAFF"
            android:textSize="10sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Active Session"
                android:textColor="#E5E2E1"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/baudRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/baud_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="● 9600 BAUD"
                android:textColor="#9ECAFF"
                android:textSize="12sp" />

        </LinearLayout>
    </LinearLayout>

    <!-- Terminal Output -->
    <ScrollView
        android:id="@+id/terminalScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:background="#0A0A0A"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/serialHeader"
        app:layout_constraintBottom_toTopOf="@id/sendCommandLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/terminalOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:text="[--:--:--] Waiting for connection...\n"/>
    </ScrollView>

    <!-- Send Label -->
    <TextView
        android:id="@+id/sendCommandLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="SEND COMMAND"
        android:textColor="#6B7280"
        android:textSize="10sp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/sendRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Send Row -->
    <LinearLayout
        android:id="@+id/sendRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/histUpBtn"
            android:layout_width="40dp"
            android:layout_height="52dp"
            android:text="▲"
            android:textColor="#9ECAFF"
            android:textSize="14sp"
            android:backgroundTint="#1A1A1A"
            android:padding="0dp"/>

        <Button
            android:id="@+id/histDownBtn"
            android:layout_width="40dp"
            android:layout_height="52dp"
            android:text="▼"
            android:textColor="#9ECAFF"
            android:textSize="14sp"
            android:backgroundTint="#1A1A1A"
            android:padding="0dp"
            android:layout_marginEnd="4dp"/>

        <EditText
            android:id="@+id/commandInput"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:hint="Type custom command..."
            android:textColorHint="#6B7280"
            android:textColor="#E5E2E1"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:inputType="text"
            android:imeOptions="actionSend"/>

        <Button
            android:id="@+id/sendBtn"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="SEND"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#2196F3"
            android:layout_marginStart="8dp"/>

        <Button
            android:id="@+id/clearBtn"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="CLEAR"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#F44336"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#161616"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
