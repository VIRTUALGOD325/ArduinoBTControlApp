<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/stat_sys_data_bluetooth"
            android:tint="#9ECAFF"
            android:layout_marginEnd="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/deviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Device"
                android:textColor="#E5E2E1"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:id="@+id/connectionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONNECTED"
                    android:textColor="#4CAF50"
                    android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/settingsBtn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_manage"
            android:tint="#9ECAFF"
            android:layout_marginEnd="14dp"
            android:padding="2dp"/>

        <Button
            android:id="@+id/disconnectBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Disconnect"
            android:backgroundTint="#C62828"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:paddingHorizontal="16dp"/>
    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="16dp">

            <!-- Mode Selector -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <TextView android:id="@+id/modeDpad"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="D-PAD" android:textColor="#9ECAFF" android:textSize="10sp" android:textStyle="bold"
                    android:gravity="center" android:background="#1E3A5F"/>

                <TextView android:id="@+id/modeJoystick"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="JOYSTICK" android:textColor="#6B7280" android:textSize="10sp" android:textStyle="bold"
                    android:gravity="center" android:background="#1A1A1A"/>

                <TextView android:id="@+id/modeVoice"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="VOICE" android:textColor="#6B7280" android:textSize="10sp" android:textStyle="bold"
                    android:gravity="center" android:background="#1A1A1A"/>

                <TextView android:id="@+id/modeTilt"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:text="TILT" android:textColor="#6B7280" android:textSize="10sp" android:textStyle="bold"
                    android:gravity="center" android:background="#1A1A1A"/>
            </LinearLayout>

            <!-- D-Pad Container -->
            <LinearLayout
                android:id="@+id/dpadContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="visible">

                <GridLayout
                    android:id="@+id/dpad"
                    android:layout_width="210dp"
                    android:layout_height="210dp"
                    android:rowCount="3"
                    android:columnCount="3"
                    android:layout_marginTop="16dp">

                    <Space android:layout_width="70dp" android:layout_height="70dp"/>
                    <Button android:id="@+id/btnForward" android:layout_width="70dp" android:layout_height="70dp" android:text="▲" android:textColor="#9ECAFF" android:textSize="20sp" android:backgroundTint="#1E1E1E"/>
                    <Space android:layout_width="70dp" android:layout_height="70dp"/>
                    <Button android:id="@+id/btnLeft" android:layout_width="70dp" android:layout_height="70dp" android:text="◀" android:textColor="#9ECAFF" android:textSize="20sp" android:backgroundTint="#1E1E1E"/>
                    <Button android:id="@+id/btnStop" android:layout_width="70dp" android:layout_height="70dp" android:backgroundTint="#2A2A2A"/>
                    <Button android:id="@+id/btnRight" android:layout_width="70dp" android:layout_height="70dp" android:text="▶" android:textColor="#9ECAFF" android:textSize="20sp" android:backgroundTint="#1E1E1E"/>
                    <Space android:layout_width="70dp" android:layout_height="70dp"/>
                    <Button android:id="@+id/btnBack" android:layout_width="70dp" android:layout_height="70dp" android:text="▼" android:textColor="#9ECAFF" android:textSize="20sp" android:backgroundTint="#1E1E1E"/>
                    <Space android:layout_width="70dp" android:layout_height="70dp"/>
                </GridLayout>
            </LinearLayout>

            <!-- Joystick Container -->
            <LinearLayout
                android:id="@+id/joystickContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone">

                <com.eduprime.arduinobt.views.JoystickView
                    android:id="@+id/joystick"
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"/>
            </LinearLayout>

            <!-- Voice Container -->
            <LinearLayout
                android:id="@+id/voiceContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingVertical="32dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/micBtn"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="🎤"
                    android:textSize="36sp"
                    android:backgroundTint="#1A2A3A"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to speak a command"
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:id="@+id/voiceStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#9ECAFF"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:layout_marginTop="12dp"
                    android:paddingHorizontal="16dp"/>
            </LinearLayout>

            <!-- Tilt Container -->
            <LinearLayout
                android:id="@+id/tiltContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingVertical="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tilt your phone to steer"
                    android:textColor="#E5E2E1"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forward · Back · Left · Right"
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tiltStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waiting..."
                    android:textColor="#9ECAFF"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>

            <!-- Speed -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SPEED ENGINE"
                    android:textColor="#9ECAFF"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/speedValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="75%"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/speedSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="75"
                android:progressTint="#2196F3"
                android:thumbTint="#FFFFFF"/>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:layout_marginTop="20dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <Button android:id="@+id/btnA" android:layout_width="64dp" android:layout_height="64dp" android:text="A" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:backgroundTint="#252525"/>
                    <TextView android:id="@+id/btnALabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOGGLE LED" android:textColor="#6B7280" android:textSize="8sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <Button android:id="@+id/btnB" android:layout_width="64dp" android:layout_height="64dp" android:text="B" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:backgroundTint="#252525"/>
                    <TextView android:id="@+id/btnBLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BUZZER" android:textColor="#6B7280" android:textSize="8sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <Button android:id="@+id/btnC" android:layout_width="64dp" android:layout_height="64dp" android:text="C" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:backgroundTint="#252525"/>
                    <TextView android:id="@+id/btnCLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AUTO MODE" android:textColor="#6B7280" android:textSize="8sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <Button android:id="@+id/btnD" android:layout_width="64dp" android:layout_height="64dp" android:text="D" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:backgroundTint="#252525"/>
                    <TextView android:id="@+id/btnDLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EMERGENCY" android:textColor="#6B7280" android:textSize="8sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#161616"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
